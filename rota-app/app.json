{
  "expo": {
    "name": "Rota",
    "slug": "rota-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rota",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rota.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kosu rotanizi haritada gostermek icin konum izni gerekiyor.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Arka planda kosu takibi icin konum izni gerekiyor.",
        "NSMotionUsageDescription": "Adim sayaci ve hareket takibi icin.",
        "NSHealthShareUsageDescription": "Kosu ve yuruyus verilerini Apple Health'ten otomatik olarak almak icin.",
        "NSHealthUpdateUsageDescription": "Kosu verilerinizi Apple Health'e kaydetmek icin."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [
          "health-records"
        ]
      }
    },
    "android": {
      "package": "com.rota.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kosu rotanizi haritada gostermek icin konum izni gerekiyor.",
          "locationAlwaysAndWhenInUsePermission": "Arka planda kosu takibi icin konum izni gerekiyor.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
